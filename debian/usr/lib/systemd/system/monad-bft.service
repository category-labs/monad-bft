[Unit]
Description="Service file for Monad BFT"
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/monad-node \
    --secp-identity ${MONAD_DATA_DIR}/private/id-secp \
    --bls-identity ${MONAD_DATA_DIR}/private/id-bls \
    --node-config ${MONAD_CONFIG_DIR}/node.toml \
    --forkpoint-config ${MONAD_DATA_DIR}/forkpoint/forkpoint.toml \
    --wal-path ${MONAD_DATA_DIR}/wal \
    --mempool-ipc-path ${MONAD_RUNTIME_DIR}/mempool.sock \
    --control-panel-ipc-path ${MONAD_RUNTIME_DIR}/controlpanel.sock \
    --statesync-ipc-path ${MONAD_RUNTIME_DIR}/statesync.sock \
    --ledger-path ${MONAD_DATA_DIR}/ledger \
    --triedb-path /dev/triedb \
    --otel-endpoint "http://127.0.0.1:4317" \
    --statesync-sq-thread-cpu 8 \
    --record-metrics-interval-seconds 1 \
    --validators-path ${MONAD_DATA_DIR}/validators/validators.toml \
    --persisted-peers-path ${MONAD_DATA_DIR}/peers.toml \
    --keystore-password "${KEYSTORE_PASSWORD}"
EnvironmentFile=-/etc/monad/env
Environment="RUST_LOG=debug,h2=warn,tower=warn,opentelemetry_sdk=warn,opentelemetry-otlp=warn"
Restart=no
DynamicUser=yes
Group=monad
SupplementaryGroups=monad-ipc
ProtectHome=read-only
NoNewPrivileges=yes
RestrictSUIDSGID=yes
LockPersonality=yes
# Sockets in /run/monad/ inherit group monad-ipc via the setgid bit on the
# directory, but file mode comes from the process umask. Default 0022 leaves
# the group without write — connect(2) needs MAY_WRITE — so rpc/execution
# (different DynamicUsers, both in monad-ipc) cannot connect. 0007 gives the
# group rw and denies world.
UMask=0007
AllowedCPUs=8-11
CPUAffinity=8,9,10,11
DeviceAllow=/dev/triedb rw
LimitNOFILE=1048576
# Hugemem configs below
LimitMEMLOCK=infinity
MemoryDenyWriteExecute=false
#SystemCallFilter=~@memlock
ProtectKernelModules=no
ProtectKernelLogs=no

[Install]
WantedBy=multi-user.target
